[Unit]
Description=dmj-vault Admin Flask service
After=network.target mysql.service mariadb.service
Wants=mysql.service mariadb.service

[Service]
Type=simple
User=www-data
Group=www-data
ExecStart=/usr/bin/dmj-vault-apps-admin-start
ExecReload=/bin/kill -HUP $MAINPID
Restart=on-failure
RestartSec=5
RuntimeDirectory=dmj-vault/sessions
RuntimeDirectoryMode=0700

[Install]
WantedBy=multi-user.target
